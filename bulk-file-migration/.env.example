# Copy this file to ".env" and fill in real values for BOTH orgs.
# The .env file holds credentials - never commit or share it.

# SOURCE org (the org you migrate FROM - read only)
SOURCE_LOGIN_URL=https://login.salesforce.com
SOURCE_USERNAME=you@source-org.com
SOURCE_PASSWORD=your-password
SOURCE_TOKEN=your-security-token

# TARGET org (the org you migrate TO)
TARGET_LOGIN_URL=https://login.salesforce.com
TARGET_USERNAME=you@target-org.com
TARGET_PASSWORD=your-password
TARGET_TOKEN=your-security-token

# Notes:
# - LOGIN_URL is https://login.salesforce.com for production/developer orgs,
#   or https://test.salesforce.com for sandboxes.
# - The security token is emailed to you from Salesforce:
#   Settings -> Reset My Security Token. Append nothing; the tool joins
#   PASSWORD + TOKEN automatically.
