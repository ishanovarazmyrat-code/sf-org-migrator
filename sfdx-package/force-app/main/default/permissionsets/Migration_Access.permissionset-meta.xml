<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Migration Access</label>
    <description>Grants read/edit on the Legacy_*_Id__c external Id fields so the migration can write them. Assign to whoever runs the migration.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <fieldPermissions>
        <field>Account.Legacy_Account_Id__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Contact.Legacy_Contact_Id__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Opportunity.Legacy_Opportunity_Id__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Case.Legacy_Case_Id__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
</PermissionSet>
